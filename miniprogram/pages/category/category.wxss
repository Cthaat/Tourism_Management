/* category.wxss - 2026 visual refactor */
@keyframes softRise {
  0% {
    opacity: 0;
    transform: translateY(14rpx);
  }

  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.container {
  min-height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 10% 9%, rgba(26, 173, 25, 0.08) 0, rgba(26, 173, 25, 0) 34%),
    radial-gradient(circle at 90% 10%, rgba(18, 150, 219, 0.08) 0, rgba(18, 150, 219, 0) 34%),
    linear-gradient(180deg, #f1f5f3 0%, #edf2f0 100%);
}

.container.dark-mode {
  background:
    radial-gradient(circle at 10% 9%, rgba(57, 208, 56, 0.14) 0, rgba(57, 208, 56, 0) 34%),
    radial-gradient(circle at 90% 10%, rgba(100, 181, 246, 0.14) 0, rgba(100, 181, 246, 0) 34%),
    linear-gradient(180deg, #111815 0%, #18221f 100%);
}

.category-header {
  width: 100%;
  box-sizing: border-box;
  padding: calc(24rpx + env(safe-area-inset-top)) 28rpx 24rpx;
  background: linear-gradient(135deg, var(--selection-color, #1aad19), var(--selection-light-color, #39d038));
  box-shadow: 0 12rpx 26rpx rgba(20, 70, 40, 0.22);
}

.category-header.dark-mode {
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.42);
}

.category-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
}

.title-dropdown-icon {
  font-size: 22rpx;
  margin-left: 10rpx;
  transform: translateY(1rpx);
}

.filter-bar {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  gap: 10rpx;
  padding: 10rpx 14rpx;
  background: rgba(255, 255, 255, 0.9);
  border-bottom: 1rpx solid rgba(43, 72, 58, 0.08);
  box-shadow: 0 6rpx 16rpx rgba(12, 26, 20, 0.08);
}

.filter-bar.dark-mode {
  background: rgba(28, 38, 34, 0.9);
  border-bottom-color: rgba(176, 208, 192, 0.12);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.35);
}

.filter-item {
  flex: 1;
  height: 70rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #567164;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.84);
  transition: all 0.2s ease;
}

.filter-item:active {
  transform: scale(0.98);
}

.filter-item.dark-mode {
  background: rgba(39, 53, 47, 0.86);
  color: #b7cbc0;
}

.filter-item.active {
  background: linear-gradient(135deg, var(--selection-color, #1aad19), var(--selection-light-color, #39d038));
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(26, 173, 25, 0.28);
}

.filter-item.active.dark-mode {
  color: #f7fff9;
  box-shadow: 0 10rpx 22rpx rgba(26, 173, 25, 0.34);
}

.filter-item.active::after {
  display: none;
}

.spot-list-container {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx 16rpx calc(18rpx + env(safe-area-inset-bottom));
  animation: softRise 0.35s ease-out;
}

.empty-view {
  margin-top: 90rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #6a8377;
  font-size: 28rpx;
}

.empty-view image {
  width: 190rpx;
  height: 190rpx;
  margin-bottom: 20rpx;
  opacity: 0.55;
}

.empty-view.dark-mode {
  color: #bfd1c7;
}

.spot-list-container spot-card {
  display: block;
  margin-bottom: 14rpx;
}

.safe-bottom {
  width: 100%;
}

.category-selector-overlay {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.26s ease;
}

.category-selector-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.category-selector-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.46);
  backdrop-filter: blur(2rpx);
}

.category-selector {
  position: relative;
  z-index: 2;
  width: 100%;
  max-height: 72vh;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 -20rpx 40rpx rgba(0, 0, 0, 0.18);
  transform: translateY(100%);
  transition: transform 0.28s ease;
}

.category-selector-overlay.show .category-selector {
  transform: translateY(0);
}

.dark-mode.category-selector {
  background: rgba(29, 38, 35, 0.96);
  border-top-color: rgba(106, 132, 120, 0.32);
  box-shadow: 0 -20rpx 40rpx rgba(0, 0, 0, 0.45);
}

.selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(43, 72, 58, 0.08);
  position: sticky;
  top: 0;
  background: inherit;
  z-index: 3;
}

.dark-mode .selector-header {
  border-bottom-color: rgba(176, 208, 192, 0.14);
}

.selector-title {
  font-size: 32rpx;
  color: #22372d;
  font-weight: 700;
}

.dark-mode .selector-title {
  color: #dce9e2;
}

.selector-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #5d776b;
  background: rgba(26, 173, 25, 0.12);
  transition: transform 0.18s ease, background-color 0.18s ease;
}

.selector-close:active {
  transform: scale(0.94);
}

.dark-mode .selector-close {
  color: #a9beb3;
  background: rgba(90, 120, 106, 0.28);
}

.selector-scroll-view {
  width: 100%;
  height: 660rpx;
  box-sizing: border-box;
  padding: 0 16rpx;
}

.selector-content {
  padding: 14rpx 0 26rpx;
}

.category-option {
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  padding: 0 20rpx;
  background: rgba(242, 248, 244, 0.95);
  border: 1rpx solid rgba(51, 90, 70, 0.08);
  transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
}

.dark-mode .category-option {
  background: rgba(42, 55, 49, 0.86);
  border-color: rgba(170, 204, 189, 0.14);
  color: #d1e3d9;
}

.category-option.active {
  background: linear-gradient(135deg, var(--selection-color, #1aad19), var(--selection-light-color, #39d038));
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 10rpx 20rpx rgba(26, 173, 25, 0.24);
}

.option-hover {
  transform: scale(0.99);
  opacity: 0.95;
}

.category-option:active {
  transform: scale(0.985);
}

.category-option-icon {
  font-size: 34rpx;
  margin-right: 14rpx;
}

.category-option-name {
  font-size: 28rpx;
  font-weight: 600;
}

@import "./category-wxa-auto-dark.wxss";
