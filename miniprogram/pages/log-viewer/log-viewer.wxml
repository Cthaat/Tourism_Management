<view class="log-viewer-container {{isDarkMode ? 'dark-mode' : ''}}" data-theme="{{colorTheme}}">
  <view class="toolbar {{isDarkMode ? 'dark-mode' : ''}}">
    <view class="search-bar {{isDarkMode ? 'dark-mode' : ''}}">
      <input
        type="text"
        placeholder="搜索日志内容 / 来源 / 级别"
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        class="search-input {{isDarkMode ? 'dark-mode' : ''}}"
      />
      <view class="search-icon {{isDarkMode ? 'dark-mode' : ''}}">🔍</view>
    </view>

    <view class="date-selector {{isDarkMode ? 'dark-mode' : ''}}">
      <view class="current-date {{isDarkMode ? 'dark-mode' : ''}} {{showDatePicker ? 'active' : ''}}" bindtap="toggleDatePicker">
        <text>📅 {{displayCurrentDate}}</text>
        <text class="dropdown-arrow {{showDatePicker ? 'open' : ''}}">▼</text>
      </view>

      <view class="date-dropdown {{showDatePicker ? 'show' : 'hide'}} {{isDarkMode ? 'dark-mode' : ''}}">
        <view
          wx:for="{{availableLogFiles}}"
          wx:key="dateString"
          class="date-option {{isDarkMode ? 'dark-mode' : ''}}"
          bindtap="selectLogDate"
          data-date="{{item.dateString}}"
        >
          {{item.displayDate}}
        </view>
        <view wx:if="{{availableLogFiles.length === 0}}" class="no-dates {{isDarkMode ? 'dark-mode' : ''}}">
          暂无日志文件
        </view>
      </view>
    </view>

    <view class="action-buttons">
      <button bindtap="exportLogs" class="action-button {{isDarkMode ? 'dark-mode' : ''}}">导出</button>
      <button bindtap="copyFilteredLogs" class="action-button {{isDarkMode ? 'dark-mode' : ''}}">复制结果</button>
      <button bindtap="refreshLogs" class="action-button {{isDarkMode ? 'dark-mode' : ''}}">刷新</button>
      <button bindtap="clearFilters" class="action-button {{isDarkMode ? 'dark-mode' : ''}}">清除过滤</button>
    </view>
  </view>

  <view class="filter-tabs {{isDarkMode ? 'dark-mode' : ''}}">
    <view class="filter-tab {{activeFilter === 'ALL' ? 'active' : ''}} {{isDarkMode ? 'dark-mode' : ''}}" bindtap="filterByLevel" data-level="ALL">全部</view>
    <view class="filter-tab {{activeFilter === 'DEBUG' ? 'active' : ''}} {{isDarkMode ? 'dark-mode' : ''}}" bindtap="filterByLevel" data-level="DEBUG">调试</view>
    <view class="filter-tab {{activeFilter === 'INFO' ? 'active' : ''}} {{isDarkMode ? 'dark-mode' : ''}}" bindtap="filterByLevel" data-level="INFO">信息</view>
    <view class="filter-tab {{activeFilter === 'WARN' ? 'active' : ''}} {{isDarkMode ? 'dark-mode' : ''}}" bindtap="filterByLevel" data-level="WARN">警告</view>
    <view class="filter-tab {{activeFilter === 'ERROR' ? 'active' : ''}} {{isDarkMode ? 'dark-mode' : ''}}" bindtap="filterByLevel" data-level="ERROR">错误</view>
  </view>

  <view class="stats-bar {{isDarkMode ? 'dark-mode' : ''}}">
    <text class="stats-item">总计: {{logStats.ALL}}</text>
    <text class="stats-item">DEBUG: {{logStats.DEBUG}}</text>
    <text class="stats-item">INFO: {{logStats.INFO}}</text>
    <text class="stats-item">WARN: {{logStats.WARN}}</text>
    <text class="stats-item">ERROR: {{logStats.ERROR}}</text>
  </view>

  <scroll-view scroll-y="true" class="logs-container {{isDarkMode ? 'dark-mode' : ''}}">
    <view wx:if="{{isLoading}}" class="loading-text {{isDarkMode ? 'dark-mode' : ''}}">
      <view class="loading-icon">⏳</view>
      <text>加载日志中...</text>
    </view>

    <view wx:elif="{{filteredLogs.length === 0}}" class="empty-logs {{isDarkMode ? 'dark-mode' : ''}}">
      <view class="empty-icon">📋</view>
      <text>当前筛选条件下无日志</text>
    </view>

    <view wx:else class="log-list">
      <view
        wx:for="{{filteredLogs}}"
        wx:key="index"
        class="log-item {{item.levelClass}} {{isDarkMode ? 'dark-mode' : ''}}"
        bindtap="copyLogItem"
        data-index="{{index}}"
      >
        <view class="log-header {{isDarkMode ? 'dark-mode' : ''}}">
          <text class="log-timestamp {{isDarkMode ? 'dark-mode' : ''}}">{{item.timestamp}}</text>
          <text class="log-level {{item.levelClass}}">{{item.level}}</text>
          <text class="log-source {{isDarkMode ? 'dark-mode' : ''}}">{{item.source}}</text>
        </view>
        <view class="log-message {{isDarkMode ? 'dark-mode' : ''}}">
          <text space="nbsp" decode>{{item.message}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer {{isDarkMode ? 'dark-mode' : ''}}">
    <text>筛选结果: {{filteredCount}} / {{logStats.ALL}}（点击单条可复制）</text>
  </view>
</view>
