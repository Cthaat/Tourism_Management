/* index.wxss - 2026 visual refactor */
page {
  height: 100vh;
  width: 100%;
  background: #eef3f1;
}

@keyframes heroDrift {
  0% {
    transform: scale(1) translateX(0);
  }

  50% {
    transform: scale(1.05) translateX(-1.2%);
  }

  100% {
    transform: scale(1) translateX(0);
  }
}

@keyframes fadeSlideUp {
  0% {
    opacity: 0;
    transform: translateY(16rpx);
  }

  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.container {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 10% 8%, rgba(26, 173, 25, 0.10) 0, rgba(26, 173, 25, 0) 36%),
    radial-gradient(circle at 90% 12%, rgba(18, 150, 219, 0.10) 0, rgba(18, 150, 219, 0) 34%),
    linear-gradient(180deg, #e8f0ec 0%, #edf3f1 100%);
}

.container.dark-mode {
  background:
    radial-gradient(circle at 10% 8%, rgba(57, 208, 56, 0.16) 0, rgba(57, 208, 56, 0) 36%),
    radial-gradient(circle at 90% 12%, rgba(100, 181, 246, 0.16) 0, rgba(100, 181, 246, 0) 34%),
    linear-gradient(180deg, #0f1714 0%, #172320 100%);
}

.fullscreen-banner {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 56vh;
  z-index: 1;
}

.banner-container {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  animation: heroDrift 14s ease-in-out infinite;
}

.banner-title {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 48rpx;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.45);
  animation: fadeSlideUp 0.5s ease-out;
}

.banner-title.dark-mode {
  color: #f2f8f4;
}

.banner-top-gradient {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 240rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.46) 0%, rgba(0, 0, 0, 0) 100%);
  z-index: 2;
}

.main-content {
  position: relative;
  z-index: 4;
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  pointer-events: none;
}

.search-container {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 18rpx);
  left: 24rpx;
  right: 24rpx;
  z-index: 30;
  pointer-events: auto;
}

.search-box {
  height: 76rpx;
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 12rpx 28rpx rgba(18, 35, 28, 0.18);
  backdrop-filter: blur(16rpx);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.search-box:active {
  transform: translateY(1rpx) scale(0.996);
}

.search-box.dark-mode {
  background: rgba(26, 36, 32, 0.88);
  border-color: rgba(90, 120, 106, 0.35);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.4);
}

.search-icon {
  font-size: 30rpx;
  color: #3e5a4d;
  margin-right: 10rpx;
}

.search-icon.dark-mode {
  color: #b3c8bd;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2a3b33;
}

.search-input.dark-mode {
  color: #e4f1e9;
}

.clear-icon {
  font-size: 24rpx;
  color: #587467;
  padding: 8rpx;
}

.clear-icon.dark-mode {
  color: #a8beb2;
}

.search-results {
  margin-top: 12rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 32rpx rgba(18, 35, 28, 0.16);
  max-height: 560rpx;
}

.search-results.dark-mode {
  background: rgba(28, 38, 34, 0.94);
  border-color: rgba(90, 120, 106, 0.35);
}

.search-loading,
.no-results {
  padding: 30rpx;
  text-align: center;
  font-size: 26rpx;
  color: #647f71;
}

.search-loading.dark-mode,
.no-results.dark-mode {
  color: #a8beb2;
}

.search-result-item {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid rgba(32, 62, 48, 0.08);
  transition: background-color 0.15s ease;
}

.search-result-item:active {
  background-color: rgba(26, 173, 25, 0.08);
}

.search-result-item:last-child {
  border-bottom: none;
}

.search-result-item.dark-mode {
  border-bottom-color: rgba(170, 204, 189, 0.12);
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-name {
  font-size: 30rpx;
  color: #20342b;
  font-weight: 600;
}

.result-name.dark-mode {
  color: #e6f2ea;
}

.result-address {
  font-size: 24rpx;
  color: #6c8679;
}

.result-address.dark-mode {
  color: #9fb6ab;
}

.result-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.result-rating {
  color: #f29b2e;
  font-size: 22rpx;
}

.result-price {
  color: #ef6055;
  font-size: 22rpx;
  font-weight: 600;
}

.scrollarea {
  pointer-events: auto;
  margin-top: 48vh;
  height: 52vh;
  width: 100%;
  padding: 26rpx 16rpx calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(16rpx);
  box-shadow: 0 -12rpx 30rpx rgba(0, 0, 0, 0.16);
}

.scrollarea.dark-mode {
  background: rgba(20, 29, 26, 0.9);
  box-shadow: 0 -12rpx 30rpx rgba(0, 0, 0, 0.5);
}

.category-container {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.category-item {
  width: calc(25% - 11rpx);
  min-height: 126rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(30, 45, 38, 0.08);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.category-item:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(30, 45, 38, 0.12);
}

.dark-mode .category-item {
  background: rgba(35, 46, 42, 0.9);
  border-color: rgba(104, 129, 117, 0.26);
}

.category-icon {
  font-size: 34rpx;
  margin-bottom: 8rpx;
}

.showcase-icon {
  color: #f6a422;
}

.category-name {
  font-size: 22rpx;
  color: #274238;
  font-weight: 600;
}

.category-name.dark-mode {
  color: #dbe9e1;
}

.section-title {
  margin: 10rpx 4rpx 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  padding-left: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f332b;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 8rpx;
  height: 30rpx;
  border-radius: 6rpx;
  transform: translateY(-50%);
  background: linear-gradient(180deg, var(--theme-color, #1aad19), var(--theme-bg-color, #4CAF50));
}

.section-title.dark-mode {
  color: #e2eee6;
}

.section-more {
  font-size: 24rpx;
  font-weight: 500;
  color: #6e887b;
}

.section-more.dark-mode {
  color: #b7cbbf;
}

.loading-container,
.empty-container {
  padding: 36rpx 24rpx;
  border-radius: 18rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.88);
  margin-bottom: 20rpx;
}

.loading-container.dark-mode,
.empty-container.dark-mode {
  background: rgba(33, 44, 40, 0.88);
}

.loading-text.dark-mode,
.empty-text.dark-mode {
  color: #c2d5ca;
}

.loading-text,
.empty-text {
  font-size: 26rpx;
  color: #5f7a6d;
}

.empty-action {
  margin-top: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--theme-color, #1aad19), var(--theme-bg-color, #4CAF50));
  color: #ffffff;
  font-size: 24rpx;
}

.hot-spots {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.hot-spot-card {
  border-radius: 22rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 12rpx 24rpx rgba(24, 40, 32, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hot-spot-card:active {
  transform: translateY(2rpx) scale(0.994);
  box-shadow: 0 8rpx 18rpx rgba(24, 40, 32, 0.14);
}

.hot-spot-card.dark-mode {
  background: rgba(34, 45, 41, 0.92);
  border-color: rgba(110, 136, 124, 0.24);
}

.spot-image {
  width: 100%;
  height: 260rpx;
}

.spot-info {
  padding: 18rpx 18rpx 16rpx;
}

.spot-info.dark-mode {
  color: #dcebe3;
}

.spot-title {
  font-size: 30rpx;
  color: #1f332b;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.spot-title.dark-mode {
  color: #e5f2ea;
}

.spot-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 23rpx;
  color: #6e877a;
  margin-bottom: 10rpx;
}

.spot-location.dark-mode {
  color: #b8ccc1;
}

.inline-icon {
  font-size: 22rpx;
}

.spot-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.spot-price {
  font-size: 24rpx;
  color: #f05648;
  font-weight: 700;
}

.spot-price.dark-mode {
  color: #ff8a7f;
}

.spot-rating {
  font-size: 22rpx;
  color: #f2a130;
}

.dark-mode .spot-rating {
  color: #f7ba52;
}

.spots-container {
  margin-bottom: 10rpx;
}

.spot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spot-item {
  width: calc(50% - 8rpx);
}

.inline-card {
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 22rpx rgba(24, 40, 32, 0.09);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.inline-card:active {
  transform: translateY(2rpx) scale(0.992);
  box-shadow: 0 6rpx 14rpx rgba(24, 40, 32, 0.14);
}

.inline-card.dark-mode {
  background: rgba(34, 45, 41, 0.94);
  border-color: rgba(110, 136, 124, 0.24);
}

.inline-image {
  width: 100%;
  height: 180rpx;
}

.inline-badge {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  z-index: 2;
  min-width: 64rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.52);
  color: #fff3cc;
  font-size: 20rpx;
}

.inline-badge.dark-mode {
  background: rgba(0, 0, 0, 0.62);
}

.inline-info {
  padding: 12rpx 12rpx 14rpx;
}

.inline-title {
  font-size: 24rpx;
  color: #1f332b;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.inline-title.dark-mode {
  color: #e5f2ea;
}

.inline-location {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #688275;
  margin-bottom: 8rpx;
}

.inline-location.dark-mode {
  color: #b7cbbf;
}

.inline-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.inline-category {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 17rpx;
  background: rgba(26, 173, 25, 0.12);
  color: var(--theme-color, #1aad19);
}

.inline-price {
  font-size: 20rpx;
  color: #ed5f53;
  font-weight: 700;
}

.inline-price.dark-mode {
  color: #ff8d84;
}

.dark-mode .free-tag {
  color: #69d889;
}

.free-tag {
  color: #26a645;
}

.safe-bottom {
  width: 100%;
}

@media (max-width: 360px) {
  .section-title {
    font-size: 30rpx;
  }

  .category-item {
    width: calc(33.333% - 10rpx);
  }

  .spot-item {
    width: 100%;
  }
}
