/* settings.wxss - Rewritten modern style system */
.settings-container {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  padding: calc(20rpx + env(safe-area-inset-top)) 22rpx calc(28rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 8% 8%, rgba(60, 190, 90, 0.08) 0, rgba(60, 190, 90, 0) 34%),
    radial-gradient(circle at 92% 12%, rgba(18, 150, 219, 0.08) 0, rgba(18, 150, 219, 0) 32%),
    linear-gradient(180deg, #f5f7f7 0%, #eef2f1 100%);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.settings-container.dark-mode {
  background:
    radial-gradient(circle at 8% 8%, rgba(57, 208, 56, 0.14) 0, rgba(57, 208, 56, 0) 34%),
    radial-gradient(circle at 92% 12%, rgba(100, 181, 246, 0.14) 0, rgba(100, 181, 246, 0) 32%),
    linear-gradient(180deg, #121716 0%, #1b2422 100%);
}

.settings-group {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 12rpx;
}

.group-title {
  padding: 12rpx 12rpx 4rpx;
  font-size: 24rpx;
  color: #7e9589;
  letter-spacing: 1rpx;
}

.group-title.dark-mode {
  color: #9eb4aa;
}

.settings-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 10rpx 24rpx rgba(25, 35, 30, 0.09);
}

.dark-mode .settings-list {
  background: rgba(34, 43, 39, 0.9);
  border-color: rgba(120, 145, 132, 0.2);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.3);
}

.setting-item {
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(40, 70, 55, 0.08);
  gap: 18rpx;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.dark-mode {
  border-bottom-color: rgba(180, 205, 192, 0.1);
}

.setting-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #23352d;
  font-weight: 500;
  line-height: 1.35;
}

.setting-name.dark-mode {
  color: #e2efe7;
}

.setting-value {
  font-size: 26rpx;
  color: #789082;
  display: flex;
  align-items: center;
}

.setting-value.dark-mode {
  color: #a8bcb1;
}

.setting-select {
  display: flex;
  align-items: center;
}

.select-value-container {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #32473d;
  max-width: 320rpx;
}

.dark-mode .select-value-container {
  color: #d4e5dc;
}

.arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 30rpx;
  font-size: 32rpx;
  color: #93a89d;
}

.dark-mode .arrow {
  color: #9fb6ab;
}

.setting-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #93a89d;
}

.setting-link.dark-mode {
  color: #9fb6ab;
}

.setting-button {
  min-width: 142rpx;
  height: 56rpx;
  padding: 0 18rpx;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--theme-color, #1aad19), var(--theme-light-color, #39d038));
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.setting-button::after {
  border: none;
}

.setting-button.dark-mode {
  opacity: 0.92;
}

switch {
  transform: scale(0.9);
  transform-origin: center;
}

.bottom-info {
  margin-top: 24rpx;
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.copyright {
  font-size: 22rpx;
  color: #8aa093;
}

.copyright.dark-mode {
  color: #8fa49a;
}

@import "./settings-wxa-auto-dark.wxss";
