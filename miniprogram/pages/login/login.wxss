/* login.wxss - Rewritten modern style system */
.container {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: calc(36rpx + env(safe-area-inset-top)) 30rpx calc(36rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 12% 12%, rgba(26, 173, 25, 0.12) 0, rgba(26, 173, 25, 0) 34%),
    radial-gradient(circle at 88% 18%, rgba(18, 150, 219, 0.12) 0, rgba(18, 150, 219, 0) 36%),
    linear-gradient(170deg, #f5f7f8 0%, #ecf2f0 100%);
}

.container.dark-mode {
  background:
    radial-gradient(circle at 12% 12%, rgba(57, 208, 56, 0.14) 0, rgba(57, 208, 56, 0) 34%),
    radial-gradient(circle at 88% 18%, rgba(100, 181, 246, 0.14) 0, rgba(100, 181, 246, 0) 36%),
    linear-gradient(170deg, #131816 0%, #1a2420 100%);
}

.login-card {
  width: 100%;
  max-width: 660rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 22rpx 56rpx rgba(30, 50, 40, 0.16);
  backdrop-filter: blur(16rpx);
}

.login-card.dark-mode {
  background: rgba(34, 42, 38, 0.92);
  border-color: rgba(110, 130, 120, 0.22);
  box-shadow: 0 24rpx 56rpx rgba(0, 0, 0, 0.42);
}

.login-card-inner {
  padding: 56rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-card-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 44rpx;
}

.login-avatar {
  width: 138rpx;
  height: 138rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 12rpx 24rpx rgba(20, 90, 30, 0.24);
  margin-bottom: 22rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1d2d25;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.login-title.dark-mode {
  color: #ecf7ef;
}

.login-subtitle {
  font-size: 26rpx;
  color: #688176;
  text-align: center;
}

.login-subtitle.dark-mode {
  color: #a8bcb1;
}

.login-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.form-item {
  width: 100%;
}

.form-label {
  display: block;
  padding-left: 8rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #2b3c33;
}

.form-label.dark-mode {
  color: #dbe9e0;
}

.password-input-container {
  width: 100%;
  position: relative;
}

.form-input {
  width: 100%;
  height: 92rpx;
  border-radius: 16rpx;
  border: 2rpx solid #d9e5de;
  background: #f8fbf9;
  box-sizing: border-box;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1f2f28;
  transition: border-color 0.2s ease, background-color 0.2s ease;
}

.form-input.dark-mode {
  background: #26322d;
  border-color: #42574d;
  color: #ecf7ef;
}

.form-input:focus {
  border-color: var(--theme-color, #1aad19);
  background: #ffffff;
}

.form-input.dark-mode:focus {
  border-color: var(--theme-light-color, #39d038);
  background: #1f2925;
}

.input-placeholder {
  color: #8ea093;
}

.input-placeholder.dark-mode {
  color: #7f9588;
}

.password-toggle {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 54rpx;
  height: 54rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(26, 173, 25, 0.1);
}

.password-toggle.dark-mode {
  background: rgba(90, 130, 110, 0.3);
}

.form-options {
  margin-top: 2rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.remember-me {
  display: flex;
  align-items: center;
  color: #60756a;
}

.remember-me.dark-mode {
  color: #a9bdb2;
}

.checkbox {
  width: 34rpx;
  height: 34rpx;
  border-radius: 8rpx;
  border: 2rpx solid #b6c8bd;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #ffffff;
}

.checkbox.checked {
  background: var(--theme-color, #1aad19);
  border-color: var(--theme-color, #1aad19);
}

.checkbox.dark-mode {
  border-color: #70897d;
  background: #26322d;
}

.checkbox.checked.dark-mode {
  background: var(--theme-color, #1aad19);
  border-color: var(--theme-color, #1aad19);
}

.checkbox-label {
  font-size: 24rpx;
}

.checkbox-label.dark-mode {
  color: #a9bdb2;
}

.forgot-password {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--theme-color, #1aad19);
}

.forgot-password.dark-mode {
  color: var(--theme-light-color, #39d038);
}

.account-login-btn {
  width: 100% !important;
  height: 92rpx;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
  background: linear-gradient(135deg, var(--theme-color, #1aad19), var(--theme-light-color, #39d038));
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 14rpx 30rpx rgba(26, 173, 25, 0.28);
}

.account-login-btn::after {
  border: none;
}

.account-login-btn:active {
  transform: translateY(1rpx) scale(0.99);
  opacity: 0.92;
}

.account-login-btn.disabled {
  background: #b8c8bf;
  box-shadow: none;
  opacity: 0.7;
}

.account-login-btn.disabled.dark-mode {
  background: #4a5a52;
  color: #9fb2a6;
}
